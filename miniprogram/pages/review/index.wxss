/* pages/review/index.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 120rpx;
}

.section {
  background-color: #ffffff;
  margin-bottom: 20rpx;
  padding: 24rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 20rpx;
}

.goods-card {
  display: flex;
  gap: 20rpx;
  padding: 16rpx;
  background-color: #fafafa;
  border-radius: 12rpx;
}

.goods-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  background-color: #ffffff;
}

.goods-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.goods-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.goods-price {
  font-size: 30rpx;
  font-weight: 600;
  color: #f56c6c;
}

.rating-section {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.star-group {
  display: flex;
  gap: 8rpx;
}

.star {
  font-size: 48rpx;
  color: #dddddd;
  transition: color 0.2s;
}

.star.active {
  color: #ffb800;
}

.rating-text {
  font-size: 26rpx;
  color: #999999;
}

.review-textarea {
  width: 100%;
  height: 200rpx;
  padding: 20rpx;
  background-color: #fafafa;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
}

.word-count {
  display: block;
  text-align: right;
  font-size: 22rpx;
  color: #999999;
  margin-top: 12rpx;
}

.upload-section {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.upload-item {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  overflow: hidden;
  position: relative;
  background-color: #fafafa;
}

.upload-item image {
  width: 100%;
  height: 100%;
}

.remove-btn {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  background-color: rgba(0, 0, 0, 0.5);
  color: #ffffff;
  font-size: 32rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.add-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #dddddd;
}

.add-icon {
  font-size: 48rpx;
  color: #999999;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  background-color: #ffffff;
  border-top: 1rpx solid #eeeeee;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  font-size: 32rpx;
  background-color: #1989fa;
  color: #ffffff;
  border-radius: 44rpx;
}