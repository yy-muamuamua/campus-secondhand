/* 学生认证页面样式 */
.page-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 20rpx;
}

.header {
  text-align: center;
  padding: 60rpx 0 40rpx;
  color: white;
}

.header-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.header-subtitle {
  font-size: 24rpx;
  opacity: 0.9;
}

.form-container {
  background: white;
  border-radius: 20rpx;
  padding: 40rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.1);
}

.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  margin-bottom: 10rpx;
  color: #333;
}

.input-field {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 10rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  transition: all 0.3s ease;
}

.input-field:focus {
  border-color: #667eea;
  box-shadow: 0 0 0 4rpx rgba(102, 126, 234, 0.1);
  outline: none;
}

.input-row {
  display: flex;
  gap: 20rpx;
  align-items: center;
}

.input-row .input-field {
  flex: 1;
}

.code-btn {
  min-width: 200rpx;
  height: 80rpx;
  background: #667eea;
  color: white;
  border: none;
  border-radius: 10rpx;
  font-size: 24rpx;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  justify-content: center;
}

.code-btn:hover {
  background: #5a6fd8;
}

.code-btn:disabled {
  background: #c0c4cc;
  cursor: not-allowed;
}

.submit-btn {
  width: 100%;
  height: 80rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 10rpx;
  font-size: 28rpx;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
  margin-top: 20rpx;
}

.submit-btn:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 5rpx 15rpx rgba(102, 126, 234, 0.3);
}

.submit-btn:disabled {
  opacity: 0.7;
  cursor: not-allowed;
  transform: none;
  box-shadow: none;
}

.loading {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

/* 响应式设计 */
@media (max-width: 375px) {
  .form-container {
    padding: 30rpx;
  }
  
  .header {
    padding: 40rpx 0 30rpx;
  }
  
  .header-title {
    font-size: 28rpx;
  }
  
  .header-subtitle {
    font-size: 22rpx;
  }
  
  .input-field,
  .code-btn,
  .submit-btn {
    height: 70rpx;
  }
  
  .form-label {
    font-size: 26rpx;
  }
  
  .input-field {
    font-size: 26rpx;
  }
  
  .code-btn {
    font-size: 22rpx;
    min-width: 180rpx;
  }
  
  .submit-btn {
    font-size: 26rpx;
  }
}

/* 动画效果 */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.form-container {
  animation: fadeIn 0.5s ease-out;
}

/* 输入框错误状态 */
.input-field.error {
  border-color: #ff4d4f;
}

/* 提示信息 */
.tip {
  font-size: 22rpx;
  color: #999;
  margin-top: 5rpx;
  margin-bottom: 20rpx;
  line-height: 1.4;
}

/* 学校邮箱提示 */
.school-email-tip {
  font-size: 22rpx;
  color: #667eea;
  margin-top: 5rpx;
  margin-bottom: 20rpx;
  line-height: 1.4;
}