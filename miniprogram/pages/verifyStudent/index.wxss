.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20px;
}

.login-container {
  padding-top: 40rpx;
}

.header {
  text-align: center;
  margin-bottom: 40rpx;
  padding-top: 20rpx;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: #999;
}

.weui-cells {
  margin-top: 0;
  border-radius: 16rpx;
  overflow: hidden;
}

.weui-cell {
  padding: 24rpx 32rpx;
}

.weui-label {
  width: 140rpx;
  font-size: 28rpx;
  color: #333;
}

.weui-select {
  font-size: 28rpx;
  color: #333;
  height: 80rpx;
  line-height: 80rpx;
}

.weui-input[disabled] {
  background-color: #f5f5f5;
  color: #999;
}

.weui-input {
  font-size: 28rpx;
  color: #333;
  height: 80rpx;
  line-height: 80rpx;
  padding: 0;
  box-sizing: border-box;
}

.weui-btn_mini {
  padding: 0 24rpx;
  font-size: 24rpx;
  line-height: 2;
}

.tips {
  margin-top: 30rpx;
  padding: 0 20rpx;
  text-align: center;
}

.tip-text {
  font-size: 24rpx;
  color: #999;
  line-height: 1.6;
}

.btn-area {
  margin-top: 40rpx;
  padding: 0 20rpx;
}

.weui-btn {
  margin-bottom: 24rpx;
  border-radius: 8rpx;
}

.weui-btn_primary {
  background-color: #1aad19;
}

.weui-btn_primary:not(.weui-btn_disabled):active {
  background-color: #129611;
}

.weui-btn_primary.weui-btn_disabled {
  background-color: #cccccc;
  color: #999999;
}
