<view class="page">
  <view class="login-container">
    <view class="header">
      <text class="title">学生认证</text>
      <text class="subtitle">完成认证解锁完整功能</text>
    </view>

    <view class="weui-cells weui-cells_form">
      <view class="weui-cell">
        <view class="weui-cell__hd">
          <view class="weui-label">学校</view>
        </view>
        <view class="weui-cell__bd">
          <input 
            class="weui-input" 
            value="昌吉学院"
            disabled
          />
        </view>
      </view>

      <view class="weui-cell">
        <view class="weui-cell__hd">
          <view class="weui-label">学号</view>
        </view>
        <view class="weui-cell__bd">
          <input 
            class="weui-input" 
            placeholder="请输入学号" 
            bindinput="bindStudentIdInput" 
            value="{{studentId}}"
          />
        </view>
      </view>

      <view class="weui-cell">
        <view class="weui-cell__hd">
          <view class="weui-label">邮箱</view>
        </view>
        <view class="weui-cell__bd">
          <input 
            class="weui-input" 
            value="{{schoolEmail}}"
            disabled
          />
        </view>
      </view>

      <view class="weui-cell">
        <view class="weui-cell__hd">
          <view class="weui-label">验证码</view>
        </view>
        <view class="weui-cell__bd">
          <input 
            class="weui-input" 
            placeholder="请输入验证码" 
            bindinput="bindVerificationCodeInput" 
            value="{{verificationCode}}"
            type="number"
          />
        </view>
        <view class="weui-cell__ft">
          <button 
            class="weui-btn weui-btn_mini weui-btn_default" 
            bindtap="sendVerificationCode"
            disabled="{{countdown > 0 || isLoading || !studentId}}"
          >
            {{countdown > 0 ? countdown + 's' : '获取验证码'}}
          </button>
        </view>
      </view>
    </view>

    <view class="tips">
      <text class="tip-text">固定使用昌吉学院进行学生认证</text>
    </view>

    <view class="btn-area">
      <button 
        class="weui-btn weui-btn_primary" 
        bindtap="submitVerification"
        disabled="{{isLoading || !studentId || !verificationCode}}"
      >
        {{isLoading ? '验证中...' : '完成认证'}}
      </button>
    </view>
  </view>
</view>
