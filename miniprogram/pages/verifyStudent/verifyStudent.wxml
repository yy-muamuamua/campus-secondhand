<view class="page">
  <!-- 页面标题 -->
  <view class="header">
    <text class="title">学生认证</text>
  </view>

  <!-- 认证表单 -->
  <view class="form">
    <!-- 学校邮箱输入 -->
    <view class="form-item">
      <text class="label">学校邮箱</text>
      <input 
        placeholder="请输入学校邮箱" 
        bindinput="onEmailInput" 
        value="{{email}}"
        type="email"
      />
      <text class="hint">请使用学校官方邮箱（如：xxx@stu.university.edu.cn）</text>
    </view>

    <!-- 学号输入 -->
    <view class="form-item">
      <text class="label">学号</text>
      <input 
        placeholder="请输入学号" 
        bindinput="onStudentIdInput" 
        value="{{studentId}}"
      />
    </view>

    <!-- 验证码输入 -->
    <view class="form-item">
      <text class="label">验证码</text>
      <view class="verify-code-container">
        <input 
          placeholder="请输入验证码" 
          bindinput="onCodeInput" 
          value="{{code}}"
          type="number"
        />
        <button 
          class="send-code-btn" 
          bindtap="sendVerificationCode"
          disabled="{{countdown > 0}}"
        >
          {{countdown > 0 ? countdown + 's后重发' : '发送验证码'}}
        </button>
      </view>
    </view>

    <!-- 提交按钮 -->
    <view class="submit-section">
      <button 
        class="submit-btn" 
        bindtap="verifyStudent"
        disabled="{{!email || !studentId || !code}}"
      >
        验证学号
      </button>
    </view>
  </view>

  <!-- 认证提示 -->
  <view class="tips">
    <text>完成学生认证后，您将获得发布商品和留言的权限</text>
  </view>
</view>