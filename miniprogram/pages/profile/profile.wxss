.page {
  min-height: 100vh;
  background: var(--background-color);
  padding-bottom: 120rpx; /* 为底部导航留出空间 */
}

/* 用户信息区域 */
.header {
  background: linear-gradient(135deg, var(--primary-color), #05a850);
  padding: 60rpx 32rpx 40rpx;
  display: flex;
  align-items: center;
  border-radius: 0 0 var(--radius-lg) var(--radius-lg);
  box-shadow: var(--shadow-md);
  margin-bottom: 24rpx;
  color: #fff;
  position: relative;
  overflow: hidden;
}

.header::before {
  content: '';
  position: absolute;
  top: 0;
  right: 0;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
  transform: translate(50%, -50%);
}

.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-right: 32rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.8);
  box-shadow: var(--shadow-md);
  flex-shrink: 0;
}

.avatar image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.info {
  flex: 1;
}

.nickname {
  font-size: 36rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 12rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
  color: #ffffff;
  background: rgba(0, 0, 0, 0.1);
  padding: 8rpx 16rpx;
  border-radius: var(--radius-md);
  display: inline-block;
}

.student {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  opacity: 0.9;
}

.student .unverified {
  color: #fff3cd;
  margin-right: 16rpx;
  font-weight: 500;
}

.student button {
  margin: 0;
  padding: 6rpx 20rpx;
  font-size: 24rpx;
  height: 48rpx;
  line-height: 48rpx;
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  border-radius: var(--radius-md);
  transition: all 0.3s ease;
}

.student button:hover {
  background: rgba(255, 255, 255, 0.3);
}

/* 菜单区域 */
.menu {
  background: var(--card-background);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  margin: 0 20rpx 20rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 32rpx;
  border-bottom: 1rpx solid var(--border-color);
  font-size: 32rpx;
  color: var(--text-primary);
  transition: all 0.3s ease;
  position: relative;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:hover {
  background: var(--background-color);
  padding-left: 40rpx;
}

.menu-item .arrow {
  font-size: 36rpx;
  color: var(--text-tertiary);
  transition: all 0.3s ease;
}

.menu-item:hover .arrow {
  transform: translateX(8rpx);
  color: var(--primary-color);
}

/* 菜单项图标 */
.menu-item::before {
  content: '';
  position: absolute;
  left: 32rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 36rpx;
  height: 36rpx;
  background-size: contain;
  background-repeat: no-repeat;
  background-position: center;
  margin-right: 16rpx;
}

.menu-item:nth-child(1)::before {
  background-image: url('/images/icons/goods.png');
}

.menu-item:nth-child(2)::before {
  background-image: url('/images/icons/settings.png');
}

.menu-item:nth-child(3)::before {
  background-image: url('/images/icons/business.png');
}

.menu-item:nth-child(4)::before {
  background-image: url('/images/icons/message.png');
}

.menu-item:nth-child(5)::before {
  background-image: url('/images/icons/admin.png');
}

/* 菜单项文本 */
.menu-item text:first-child {
  margin-left: 56rpx;
  font-weight: 500;
}

/* 加载状态 */
.loading {
  text-align: center;
  padding: 150rpx 0;
  color: var(--text-tertiary);
  font-size: 28rpx;
}

/* 响应式设计 */
@media screen and (min-width: 750rpx) {
  .header {
    max-width: 750rpx;
    margin: 0 auto 24rpx;
    border-radius: var(--radius-lg);
  }
  
  .menu {
    max-width: 750rpx;
    margin: 0 auto 20rpx;
  }
}

@media screen and (max-width: 375rpx) {
  .header {
    padding: 40rpx 24rpx 32rpx;
  }
  
  .avatar {
    width: 120rpx;
    height: 120rpx;
  }
  
  .nickname {
    font-size: 32rpx;
  }
  
  .menu-item {
    padding: 28rpx 24rpx;
  }
  
  .menu-item text:first-child {
    margin-left: 48rpx;
  }
}