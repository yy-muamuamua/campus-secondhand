/* 个人中心页面样式 - 极简主义 + 莫兰迪色系 */

.page {
  min-height: 100vh;
  background: var(--background-color);
  padding-bottom: 140rpx;
}

/* 用户信息头部 */
.user-header {
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  padding: 60rpx var(--spacing-lg) 40rpx;
  border-radius: 0 0 var(--radius-xl) var(--radius-xl);
  display: flex;
  align-items: center;
  position: relative;
  overflow: hidden;
}

.header-decoration {
  position: absolute;
  top: -50%;
  right: -20%;
  width: 300rpx;
  height: 300rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.user-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  margin-right: var(--spacing-lg);
  border: 4rpx solid rgba(255, 255, 255, 0.6);
  box-shadow: var(--shadow-md);
  flex-shrink: 0;
}

.user-info {
  flex: 1;
  z-index: 1;
}

.user-name {
  font-size: var(--font-xl);
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: var(--spacing-xs);
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
}

.user-meta {
  display: flex;
  align-items: center;
  gap: var(--spacing-md);
}

.user-id {
  font-size: var(--font-sm);
  color: rgba(255, 255, 255, 0.8);
}

.verify-badge {
  padding: 4rpx 12rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  font-size: var(--font-xs);
  color: #FFFFFF;
}

.verify-btn {
  padding: 8rpx 20rpx;
  background: rgba(255, 255, 255, 0.2);
  border: 1rpx solid rgba(255, 255, 255, 0.4);
  border-radius: var(--radius-md);
  font-size: var(--font-xs);
  color: #FFFFFF;
}

.verify-btn:active {
  background: rgba(255, 255, 255, 0.3);
}

/* 统计数据卡片 */
.stats-card {
  background: var(--card-background);
  margin: -30rpx var(--spacing-md) var(--spacing-md);
  padding: var(--spacing-lg);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-md);
  position: relative;
  z-index: 10;
}

.stats-grid {
  display: flex;
  justify-content: space-around;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--spacing-xs);
}

.stat-value {
  font-size: var(--font-xl);
  font-weight: 600;
  color: var(--text-primary);
}

.stat-label {
  font-size: var(--font-xs);
  color: var(--text-tertiary);
}

/* 功能菜单 */
.menu-section {
  padding: 0 var(--spacing-md);
}

.menu-card {
  background: var(--card-background);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-sm);
  overflow: hidden;
  margin-bottom: var(--spacing-md);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: var(--spacing-lg);
  border-bottom: 1rpx solid var(--border-color);
  transition: all 0.2s ease;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: var(--background-color);
}

.menu-icon {
  width: 48rpx;
  height: 48rpx;
  margin-right: var(--spacing-md);
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.menu-icon-primary {
  background: var(--primary-light);
  color: var(--primary-color);
}

.menu-icon-accent {
  background: rgba(201, 167, 167, 0.2);
  color: var(--accent-pink);
}

.menu-icon-blue {
  background: rgba(139, 164, 180, 0.2);
  color: var(--accent-blue);
}

.menu-icon-beige {
  background: rgba(212, 196, 176, 0.2);
  color: var(--accent-beige);
}

.menu-icon-lavender {
  background: rgba(184, 180, 196, 0.2);
  color: var(--accent-lavender);
}

.menu-content {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.menu-title {
  font-size: var(--font-base);
  font-weight: 500;
  color: var(--text-primary);
}

.menu-extra {
  display: flex;
  align-items: center;
  gap: var(--spacing-xs);
}

.menu-text {
  font-size: var(--font-sm);
  color: var(--text-tertiary);
}

.menu-arrow {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.5;
}

/* 操作按钮区 */
.actions-section {
  padding: 0 var(--spacing-md) var(--spacing-lg);
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--spacing-md);
}

.action-item {
  background: var(--card-background);
  padding: var(--spacing-lg) var(--spacing-md);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-sm);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--spacing-sm);
  transition: all 0.2s ease;
}

.action-item:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-md);
}

.action-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.action-title {
  font-size: var(--font-sm);
  color: var(--text-primary);
  font-weight: 500;
}

/* 底部安全区域 */
.footer-safe {
  padding-bottom: env(safe-area-inset-bottom);
}

/* 加载状态 */
.loading-container {
  padding: 200rpx var(--spacing-lg);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--spacing-md);
}

/* 响应式设计 */
@media screen and (min-width: 750rpx) {
  .page {
    max-width: 750rpx;
    margin: 0 auto;
    box-shadow: 0 0 24rpx rgba(0, 0, 0, 0.1);
  }
  
  .user-header {
    border-radius: var(--radius-xl);
    margin-bottom: var(--spacing-md);
  }
  
  .stats-card {
    margin-left: auto;
    margin-right: auto;
    max-width: calc(750rpx - var(--spacing-xl));
  }
  
  .menu-section,
  .actions-section {
    max-width: 750rpx;
    margin-left: auto;
    margin-right: auto;
  }
}

@media screen and (max-width: 320rpx) {
  .user-header {
    padding: 40rpx var(--spacing-md) 32rpx;
  }
  
  .user-avatar {
    width: 120rpx;
    height: 120rpx;
  }
  
  .user-name {
    font-size: var(--font-lg);
  }
  
  .menu-item {
    padding: var(--spacing-md);
  }
  
  .stat-value {
    font-size: var(--font-lg);
  }
}
