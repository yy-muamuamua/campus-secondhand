.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 20rpx;
}

.header {
  background: linear-gradient(135deg, #688677 0%, #4a6359 100%);
  padding: 60rpx 32rpx 40rpx;
  display: flex;
  align-items: center;
}

.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  margin-right: 32rpx;
  overflow: hidden;
  border: 4rpx solid rgba(255, 255, 255, 0.6);
}

.avatar image {
  width: 100%;
  height: 100%;
}

.info {
  flex: 1;
}

.nickname {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  display: block;
  margin-bottom: 12rpx;
}

.student {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.student text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

.unverified {
  color: rgba(255, 200, 200, 0.9);
}

.student button {
  font-size: 24rpx;
  padding: 0 20rpx;
  height: 52rpx;
  line-height: 52rpx;
  background: rgba(255, 255, 255, 0.2);
  border: 1rpx solid rgba(255, 255, 255, 0.4);
  color: #fff;
  border-radius: 26rpx;
}

.menu {
  margin: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item text {
  font-size: 30rpx;
  color: #333;
}

.arrow {
  font-size: 36rpx;
  color: #999;
}

.loading {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
}

/* 未登录提示 */
.login-prompt-section {
  background: linear-gradient(135deg, #688677 0%, #4a6359 100%);
  padding: 80rpx 32rpx;
}

.login-prompt {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.login-icon {
  margin-bottom: 24rpx;
  opacity: 0.8;
}

.login-text {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* weui样式 */
.weui-panel {
  margin: 24rpx;
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
}

.weui-panel__hd {
  padding: 24rpx 32rpx;
  font-size: 28rpx;
  color: #999999;
  font-weight: 500;
  border-bottom: 1rpx solid #e5e5e5;
}

.weui-panel__bd {
  padding: 0;
}

.weui-cells {
  margin: 0;
}

.weui-cell {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #e5e5e5;
}

.weui-cell:last-child {
  border-bottom: none;
}

.weui-cell__hd {
  margin-right: 24rpx;
}

.weui-cell__bd {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

.weui-cell__ft {
  display: flex;
  align-items: center;
}
