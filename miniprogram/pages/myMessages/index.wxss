.page {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}
.message-item {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}
.goods-info {
  display: flex;
  align-items: center;
  margin-bottom: 15rpx;
  padding-bottom: 15rpx;
  border-bottom: 1rpx solid #eee;
}
.goods-info image {
  width: 80rpx;
  height: 80rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
}
.goods-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.message-content, .reply-content {
  margin-bottom: 15rpx;
  padding-left: 20rpx;
}
.question, .answer {
  display: block;
  font-size: 30rpx;
  color: #333;
  line-height: 1.5;
}
.time, .reply-time {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}
.reply-content {
  background: #f8f8f8;
  padding: 15rpx;
  border-radius: 8rpx;
  margin-top: 10rpx;
}
.no-reply {
  font-size: 28rpx;
  color: #f60;
  margin-top: 10rpx;
  padding-left: 20rpx;
}
.empty, .loading {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
}
