<view class="page">
  <view class="message-list">
    <view wx:for="{{messages}}" wx:key="_id" class="message-item" data-id="{{item.goods_id}}" bindtap="goToDetail">
      <view class="goods-info">
        <image src="{{item.goodsInfo.image}}" mode="aspectFill" />
        <text class="goods-title">{{item.goodsInfo.title}}</text>
      </view>
      <view class="message-content">
        <text class="question">问：{{item.content}}</text>
        <text class="time">{{formatTime(item.create_time)}}</text>
      </view>
      <view wx:if="{{item.reply}}" class="reply-content">
        <text class="answer">答：{{item.reply}}</text>
        <text class="reply-time">{{formatTime(item.reply_time)}}</text>
      </view>
      <view wx:else class="no-reply">卖家尚未回复</view>
    </view>
  </view>

  <view class="empty" wx:if="{{!loading && messages.length === 0}}">
    暂无咨询记录
  </view>
  <view class="loading" wx:if="{{loading}}">加载中...</view>
</view>