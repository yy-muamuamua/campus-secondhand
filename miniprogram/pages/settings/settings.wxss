/* 设置页面样式 - WeUI风格 */
.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

.weui-panel {
  margin: 24rpx;
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
}

.weui-panel__hd {
  padding: 24rpx 32rpx;
  font-size: 26rpx;
  color: #999999;
  font-weight: 500;
  border-bottom: 1rpx solid #e5e5e5;
}

.weui-panel__bd {
  padding: 0;
}

.weui-cells {
  margin: 0;
}

.weui-cell {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #e5e5e5;
}

.weui-cell:last-child {
  border-bottom: none;
}

.weui-cell__hd {
  margin-right: 24rpx;
}

.weui-cell__bd {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

.weui-cell__ft {
  display: flex;
  align-items: center;
}

.weui-switch {
  transform: scale(0.9);
}



.logout-section {
  padding: 40rpx 24rpx;
}

.weui-btn {
  width: 100%;
  border-radius: 8rpx;
}

.weui-btn_default {
  background-color: #ffffff;
  color: #666666;
  border: 1rpx solid #d9d9d9;
}

.weui-btn_default:not(.weui-btn_disabled):active {
  background-color: #f5f5f5;
}
