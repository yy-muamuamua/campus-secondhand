.page {
  min-height: 100vh;
  background: var(--background-color);
  padding-bottom: 120rpx; /* 为底部导航留出空间 */
}

/* 页面标题 */
.header {
  background: linear-gradient(135deg, var(--primary-color), #05a850);
  padding: 60rpx 32rpx 40rpx;
  border-radius: 0 0 var(--radius-lg) var(--radius-lg);
  box-shadow: var(--shadow-md);
  margin-bottom: 24rpx;
  position: relative;
  overflow: hidden;
}

.header::before {
  content: '';
  position: absolute;
  top: 0;
  right: 0;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
  transform: translate(50%, -50%);
}

.header .title {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  text-align: center;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
}

/* 设置菜单 */
.menu {
  margin: 0 20rpx;
}

/* 菜单区块 */
.menu-section {
  background: var(--card-background);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  margin-bottom: 20rpx;
  overflow: hidden;
}

/* 区块标题 */
.section-title {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text-tertiary);
  padding: 20rpx 32rpx 12rpx;
  letter-spacing: 1rpx;
}

/* 菜单项 */
.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx 32rpx;
  border-bottom: 1rpx solid var(--border-color);
  transition: all 0.3s ease;
  position: relative;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:hover {
  background: var(--background-color);
  padding-left: 40rpx;
}

/* 菜单项图标 */
.item-icon {
  font-size: 36rpx;
  margin-right: 24rpx;
  width: 48rpx;
  text-align: center;
  position: absolute;
  left: 32rpx;
  top: 50%;
  transform: translateY(-50%);
}

/* 菜单项文本 */
.item-text {
  flex: 1;
  font-size: 32rpx;
  color: var(--text-primary);
  font-weight: 500;
  margin-left: 72rpx;
}

/* 箭头 */
.arrow {
  font-size: 36rpx;
  color: var(--text-tertiary);
  transition: all 0.3s ease;
}

.menu-item:hover .arrow {
  transform: translateX(8rpx);
  color: var(--primary-color);
}

/* 开关 */
.switch {
  transform: scale(0.8);
  margin-left: 72rpx;
}

/* 退出登录 */
.logout-section {
  padding: 40rpx 0;
  margin: 0 20rpx;
}

.logout-btn {
  width: 100%;
  height: 80rpx;
  font-size: 32rpx;
  font-weight: 500;
  color: var(--error-color);
  background: var(--card-background);
  border: 1rpx solid var(--error-color);
  border-radius: var(--radius-md);
  transition: all 0.3s ease;
  box-shadow: var(--shadow-sm);
}

.logout-btn:hover {
  background: var(--error-color);
  color: #fff;
  transform: translateY(-2rpx);
  box-shadow: var(--shadow-md);
}

/* 响应式设计 */
@media screen and (min-width: 750rpx) {
  .header {
    max-width: 750rpx;
    margin: 0 auto 24rpx;
    border-radius: var(--radius-lg);
  }
  
  .menu {
    max-width: 750rpx;
    margin: 0 auto;
  }
  
  .logout-section {
    max-width: 750rpx;
    margin: 0 auto;
  }
}

@media screen and (max-width: 375rpx) {
  .header {
    padding: 40rpx 24rpx 32rpx;
  }
  
  .header .title {
    font-size: 32rpx;
  }
  
  .menu {
    margin: 0 16rpx;
  }
  
  .menu-section {
    margin-bottom: 16rpx;
  }
  
  .section-title {
    font-size: 24rpx;
    padding: 16rpx 24rpx 10rpx;
  }
  
  .menu-item {
    padding: 28rpx 24rpx;
  }
  
  .menu-item:hover {
    padding-left: 32rpx;
  }
  
  .item-icon {
    font-size: 32rpx;
    width: 40rpx;
    left: 24rpx;
  }
  
  .item-text {
    font-size: 28rpx;
    margin-left: 64rpx;
  }
  
  .arrow {
    font-size: 32rpx;
  }
  
  .switch {
    margin-left: 64rpx;
  }
  
  .logout-section {
    margin: 0 16rpx;
  }
  
  .logout-btn {
    height: 72rpx;
    font-size: 28rpx;
  }
}