<view class="page">
  <view class="weui-panel">
    <view class="weui-panel__hd">通知设置</view>
    <view class="weui-panel__bd">
      <view class="weui-cells">
        <view class="weui-cell" bindtap="toggleMessageNotificationTap">
          <view class="weui-cell__hd">
            <mp-icon type="message" size="28" color="{{messageNotification ? '#1aad19' : '#999999'}}" />
          </view>
          <view class="weui-cell__bd">
            <view style="font-size: 28rpx; color: #333333;">消息通知</view>
            <view style="font-size: 24rpx; color: #999999; margin-top: 8rpx;">接收聊天消息、评论回复等互动通知</view>
          </view>
          <view class="weui-cell__ft">
            <switch 
              class="weui-switch" 
              checked="{{messageNotification}}" 
              bindchange="toggleMessageNotification"
            />
          </view>
        </view>
        <view class="weui-cell" bindtap="toggleSystemNotificationTap">
          <view class="weui-cell__hd">
            <mp-icon type="info" size="28" color="{{systemNotification ? '#1890ff' : '#999999'}}" />
          </view>
          <view class="weui-cell__bd">
            <view style="font-size: 28rpx; color: #333333;">系统通知</view>
            <view style="font-size: 24rpx; color: #999999; margin-top: 8rpx;">接收订单状态、系统公告等重要通知</view>
          </view>
          <view class="weui-cell__ft">
            <switch 
              class="weui-switch" 
              checked="{{systemNotification}}" 
              bindchange="toggleSystemNotification"
            />
          </view>
        </view>
        <view class="weui-cell" bindtap="togglePushNotificationTap">
          <view class="weui-cell__hd">
            <mp-icon type="push" size="28" color="{{pushNotification ? '#722ed1' : '#999999'}}" />
          </view>
          <view class="weui-cell__bd">
            <view style="font-size: 28rpx; color: #333333;">推送通知</view>
            <view style="font-size: 24rpx; color: #999999; margin-top: 8rpx;">接收小程序服务通知推送</view>
          </view>
          <view class="weui-cell__ft">
            <switch 
              class="weui-switch" 
              checked="{{pushNotification}}" 
              bindchange="togglePushNotification"
            />
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="weui-panel">
    <view class="weui-panel__hd">关于</view>
    <view class="weui-panel__bd">
      <view class="weui-cells weui-cells_access">
        <view class="weui-cell" bindtap="goToAbout">
          <view class="weui-cell__hd">
            <mp-icon type="info" size="28" color="#999999" />
          </view>
          <view class="weui-cell__bd">关于我们</view>
          <view class="weui-cell__ft">
            <mp-icon type="arrow" size="24" color="#999999" />
          </view>
        </view>
        <view class="weui-cell" bindtap="goToFeedback">
          <view class="weui-cell__hd">
            <mp-icon type="edit" size="28" color="#1aad19" />
          </view>
          <view class="weui-cell__bd">意见反馈</view>
          <view class="weui-cell__ft">
            <mp-icon type="arrow" size="24" color="#999999" />
          </view>
        </view>
        <view class="weui-cell" bindtap="goToPrivacy">
          <view class="weui-cell__hd">
            <mp-icon type="safe" size="28" color="#1890ff" />
          </view>
          <view class="weui-cell__bd">隐私政策</view>
          <view class="weui-cell__ft">
            <mp-icon type="arrow" size="24" color="#999999" />
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="logout-section">
    <button class="weui-btn weui-btn_default" bindtap="logout">退出登录</button>
  </view>

  <mp-toast id="toast" />
  <mp-dialog show="{{showDialog}}" title="{{dialogTitle}}" content="{{dialogContent}}" bindbuttontap="onDialogTap" buttons="{{dialogButtons}}" />
</view>
