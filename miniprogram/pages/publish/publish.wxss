/* 发布商品页面样式 - WeUI风格 */
.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx;
}

.weui-cells {
  margin-top: 0;
  border-radius: 0;
}

.weui-cells_form {
  background: #ffffff;
}

.weui-cell {
  padding: 24rpx 32rpx;
}

.weui-label {
  width: 140rpx;
  font-size: 28rpx;
  color: #333333;
}

.weui-input {
  font-size: 28rpx;
  color: #333333;
}

.weui-textarea {
  font-size: 28rpx;
  color: #333333;
  min-height: 160rpx;
}

.weui-cell__ft {
  color: #999999;
  font-size: 28rpx;
}

.weui-select {
  font-size: 28rpx;
  color: #333333;
}

/* 图片上传样式 */
.weui-uploader {
  padding: 24rpx 0;
}

.weui-uploader__hd {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 32rpx 16rpx;
}

.weui-uploader__title {
  font-size: 28rpx;
  color: #333333;
}

.weui-uploader__info {
  font-size: 24rpx;
  color: #999999;
}

.weui-uploader__bd {
  padding: 0 32rpx;
}

.weui-uploader__files {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
}

.weui-uploader__file {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.weui-uploader__img {
  width: 100%;
  height: 100%;
  border-radius: 8rpx;
}

.weui-uploader__file-close {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.6);
  border-radius: 50%;
  color: #ffffff;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.weui-uploader__input-box {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed #d9d9d9;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.weui-uploader__input {
  width: 100%;
  height: 100%;
}

.btn-area {
  margin-top: 60rpx;
  padding: 0 32rpx;
}

.weui-btn {
  border-radius: 8rpx;
}

.weui-btn_primary {
  background-color: #1aad19;
}

.weui-btn_primary:not(.weui-btn_disabled):active {
  background-color: #129611;
}
