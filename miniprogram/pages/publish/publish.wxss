/* 发布商品页面样式 - 极简主义 + 莫兰迪色系 */

.page {
  min-height: 100vh;
  background: var(--background-color);
  padding-bottom: 140rpx;
}

/* 页面头部 */
.publish-header {
  background: var(--card-background);
  padding: var(--spacing-lg);
  border-bottom: 1rpx solid var(--border-color);
}

.header-title {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--text-primary);
  text-align: center;
}

/* 表单区域 */
.form-container {
  padding: var(--spacing-lg);
}

.form-section {
  background: var(--card-background);
  border-radius: var(--radius-xl);
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-md);
  box-shadow: var(--shadow-sm);
}

.section-title {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  margin-bottom: var(--spacing-md);
}

.section-line {
  width: 4rpx;
  height: 28rpx;
  background: var(--primary-color);
  border-radius: 2rpx;
}

.section-label {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--text-primary);
}

.form-group {
  margin-bottom: var(--spacing-lg);
}

.form-group:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: var(--font-base);
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: var(--spacing-sm);
}

.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 var(--spacing-md);
  border: 1rpx solid var(--border-color);
  border-radius: var(--radius-md);
  font-size: var(--font-base);
  color: var(--text-primary);
  background: var(--background-color);
  transition: all 0.2s ease;
  box-sizing: border-box;
}

.form-input:focus {
  border-color: var(--primary-color);
  outline: 2rpx solid var(--primary-light);
  outline-offset: 2rpx;
}

.form-textarea {
  width: 100%;
  min-height: 180rpx;
  padding: var(--spacing-md);
  border: 1rpx solid var(--border-color);
  border-radius: var(--radius-md);
  font-size: var(--font-base);
  color: var(--text-primary);
  background: var(--background-color);
  resize: none;
  transition: all 0.2s ease;
  box-sizing: border-box;
  line-height: 1.5;
}

.form-textarea:focus {
  border-color: var(--primary-color);
  outline: 2rpx solid var(--primary-light);
  outline-offset: 2rpx;
}

.form-textarea::placeholder,
.form-input::placeholder {
  color: var(--text-tertiary);
}

/* 分类选择器 */
.category-picker {
  width: 100%;
  height: 88rpx;
  padding: 0 var(--spacing-md);
  border: 1rpx solid var(--border-color);
  border-radius: var(--radius-md);
  font-size: var(--font-base);
  color: var(--text-primary);
  background: var(--background-color);
  display: flex;
  align-items: center;
  justify-content: space-between;
  transition: all 0.2s ease;
}

.category-picker:active {
  border-color: var(--primary-color);
}

.category-arrow {
  width: 0;
  height: 0;
  border-left: 12rpx solid var(--text-tertiary);
  border-top: 8rpx solid transparent;
  border-bottom: 8rpx solid transparent;
}

/* 图片上传区域 */
.image-upload-area {
  margin-top: var(--spacing-sm);
}

.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacing-sm);
  margin-bottom: var(--spacing-md);
}

.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: var(--radius-md);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
  transition: all 0.2s ease;
}

.image-item:active {
  transform: scale(0.98);
}

.image-item image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.remove-btn {
  position: absolute;
  top: var(--spacing-xs);
  right: var(--spacing-xs);
  width: 48rpx;
  height: 48rpx;
  background: rgba(0, 0, 0, 0.6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #FFFFFF;
}

.remove-btn:active {
  background: var(--error-color);
}

.add-image-btn {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed var(--border-color);
  border-radius: var(--radius-md);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--spacing-xs);
  transition: all 0.2s ease;
}

.add-image-btn:active {
  border-color: var(--primary-color);
  background: var(--primary-light);
}

.add-icon {
  width: 48rpx;
  height: 48rpx;
  border: 2rpx solid var(--text-tertiary);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: var(--text-tertiary);
}

.add-text {
  font-size: var(--font-xs);
  color: var(--text-tertiary);
}

/* 价格输入区域 */
.price-input-row {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
}

.price-symbol {
  font-size: var(--font-md);
  color: var(--text-secondary);
  font-weight: 500;
}

.price-input {
  flex: 1;
}

.price-unit {
  font-size: var(--font-sm);
  color: var(--text-tertiary);
}

/* 底部发布按钮 */
.publish-btn-container {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: var(--spacing-md);
  padding-bottom: calc(var(--spacing-md) + env(safe-area-inset-bottom));
  background: var(--card-background);
  box-shadow: 0 -2rpx 12rpx rgba(107, 142, 123, 0.08);
  z-index: 1000;
}

.publish-btn {
  width: 100%;
  height: 88rpx;
  background: var(--primary-color);
  color: #FFFFFF;
  border-radius: var(--radius-lg);
  font-size: var(--font-md);
  font-weight: 500;
  transition: all 0.2s ease;
}

.publish-btn:active {
  background: var(--primary-dark);
  transform: scale(0.99);
}

.publish-btn:disabled {
  background: var(--text-tertiary);
  opacity: 0.6;
}

/* 加载状态 */
.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--spacing-md);
  z-index: 9999;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid var(--border-color);
  border-top-color: var(--primary-color);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: var(--font-base);
  color: #FFFFFF;
}

/* 响应式设计 */
@media screen and (min-width: 750rpx) {
  .page {
    max-width: 750rpx;
    margin: 0 auto;
    box-shadow: 0 0 24rpx rgba(0, 0, 0, 0.1);
  }
  
  .form-container {
    padding: var(--spacing-xl);
  }
  
  .image-item,
  .add-image-btn {
    width: 220rpx;
    height: 220rpx;
  }
  
  .publish-btn-container {
    max-width: 750rpx;
    left: 50%;
    transform: translateX(-50%);
    border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  }
}

@media screen and (max-width: 320rpx) {
  .form-container {
    padding: var(--spacing-md);
  }
  
  .form-section {
    padding: var(--spacing-md);
  }
  
  .image-item,
  .add-image-btn {
    width: 160rpx;
    height: 160rpx;
  }
  
  .form-input,
  .category-picker {
    height: 72rpx;
  }
  
  .form-textarea {
    min-height: 140rpx;
  }
}
