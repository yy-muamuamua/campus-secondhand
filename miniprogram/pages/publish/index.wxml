<view class="page">
  <view class="weui-cells weui-cells_form">
    <view class="weui-cell">
      <view class="weui-cell__hd">
        <view class="weui-label">标题</view>
      </view>
      <view class="weui-cell__bd">
        <input class="weui-input" placeholder="请输入商品标题" bindinput="onTitleInput" value="{{title}}" />
      </view>
    </view>

    <view class="weui-cell">
      <view class="weui-cell__hd">
        <view class="weui-label">描述</view>
      </view>
      <view class="weui-cell__bd">
        <textarea class="weui-textarea" placeholder="请输入商品描述" bindinput="onDescInput" value="{{description}}" auto-height />
      </view>
    </view>

    <view class="weui-cell">
      <view class="weui-cell__hd">
        <view class="weui-label">价格</view>
      </view>
      <view class="weui-cell__bd">
        <input class="weui-input" placeholder="请输入价格" type="digit" bindinput="onPriceInput" value="{{price}}" />
      </view>
      <view class="weui-cell__ft">元</view>
    </view>

    <view class="weui-cell weui-cell_select">
      <view class="weui-cell__hd">
        <view class="weui-label">分类</view>
      </view>
      <view class="weui-cell__bd">
        <picker bindchange="onCategoryChange" value="{{categoryIndex}}" range="{{categories}}">
          <view class="weui-select">{{category}}</view>
        </picker>
      </view>
    </view>

    <view class="weui-cell">
      <view class="weui-cell__bd">
        <view class="weui-uploader">
          <view class="weui-uploader__hd">
            <view class="weui-uploader__title">图片</view>
            <view class="weui-uploader__info">{{images.length}}/9</view>
          </view>
          <view class="weui-uploader__bd">
            <view class="weui-uploader__files">
              <block wx:for="{{images}}" wx:key="index">
                <view class="weui-uploader__file">
                  <image class="weui-uploader__img" src="{{item}}" mode="aspectFill" />
                  <view class="weui-uploader__file-close" bindtap="onRemoveImage" data-index="{{index}}">×</view>
                </view>
              </block>
            </view>
            <view class="weui-uploader__input-box" wx:if="{{images.length < 9}}">
              <view class="weui-uploader__input" bindtap="uploadImages"></view>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="btn-area">
    <button class="weui-btn weui-btn_primary" bindtap="onPublish" disabled="{{isPublishing}}">
      {{isPublishing ? '发布中...' : '发布'}}
    </button>
  </view>

  <mp-toast id="toast" />
  <mp-dialog show="{{showDialog}}" title="{{dialogTitle}}" content="{{dialogContent}}" bindbuttontap="onDialogTap" buttons="{{dialogButtons}}" />
</view>
