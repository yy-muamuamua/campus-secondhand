/* 用户中心页面样式 - 简洁稳定版 */
.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

.user-card {
  margin: 24rpx;
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
}

.user-header {
  display: flex;
  align-items: center;
  padding: 32rpx;
}

.avatar-wrapper {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-right: 24rpx;
  background: #f0f0f0;
  flex-shrink: 0;
}

.avatar {
  width: 100%;
  height: 100%;
}

.user-info {
  flex: 1;
}

.nickname {
  font-size: 32rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 8rpx;
}

.student-id, .unverified {
  font-size: 26rpx;
  color: #999999;
}

.unverified {
  color: #ff9900;
}

.arrow {
  font-size: 28rpx;
  color: #c0c0c0;
  margin-left: 16rpx;
}

.weui-panel {
  margin: 0 24rpx 24rpx;
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
}

.weui-panel__hd {
  padding: 24rpx 32rpx;
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  border-bottom: 1rpx solid #e5e5e5;
}

.weui-panel__bd {
  padding: 0;
}

.weui-cells {
  margin: 0;
}

.weui-cell {
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #e5e5e5;
}

.weui-cell:last-child {
  border-bottom: none;
}

.weui-cell__bd {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

.weui-cell__ft {
  display: flex;
  align-items: center;
}

.weui-loadmore {
  text-align: center;
  padding: 100rpx 0;
}

.weui-loading {
  display: inline-block;
  width: 32rpx;
  height: 32rpx;
  border: 3rpx solid #d9d9d9;
  border-top-color: #1aad19;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-right: 16rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.weui-loadmore__tips {
  font-size: 28rpx;
  color: #999999;
}