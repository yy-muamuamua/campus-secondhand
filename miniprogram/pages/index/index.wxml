<view class="page">
  <!-- 头部：分类切换和搜索 -->
  <view class="header">
    <scroll-view scroll-x class="category-scroll">
      <view class="category-list">
        <view 
          wx:for="{{categories}}" 
          wx:key="index"
          class="category-item {{currentCategory === item ? 'active' : ''}}"
          data-category="{{item}}"
          bindtap="switchCategory"
        >{{item}}</view>
      </view>
    </scroll-view>
    <view class="filter-icons">
      <view class="icon-item" bindtap="toggleSortPanel">
        <text>🔽</text>
      </view>
      <view class="icon-item" bindtap="togglePriceFilter">
        <text>💰</text>
      </view>
      <view class="search-icon" bindtap="showSearch">
        <text>🔍</text>
      </view>
    </view>
  </view>

  <!-- 排序面板（下拉） -->
  <view class="sort-panel" wx:if="{{showSortPanel}}">
    <view 
      wx:for="{{sortOptions}}" 
      wx:key="index"
      class="sort-option {{sortIndex === index ? 'active' : ''}}"
      data-index="{{index}}"
      bindtap="selectSort"
    >{{item.label}}</view>
  </view>

  <!-- 价格筛选面板 -->
  <view class="price-filter" wx:if="{{showPriceFilter}}">
    <view class="price-inputs">
      <input placeholder="最低价" type="number" bindinput="onMinPriceInput" value="{{minPrice}}" />
      <text>—</text>
      <input placeholder="最高价" type="number" bindinput="onMaxPriceInput" value="{{maxPrice}}" />
    </view>
    <view class="price-actions">
      <button size="mini" bindtap="clearPriceFilter">清除</button>
      <button size="mini" type="primary" bindtap="applyPriceFilter">确定</button>
    </view>
  </view>

  <!-- 搜索框（条件显示） -->
  <view class="search-box" wx:if="{{showSearchInput}}">
    <input 
      placeholder="输入商品名称" 
      bindinput="onSearchInput" 
      value="{{keyword}}"
      confirm-type="search"
      bindconfirm="onSearch"
    />
    <button size="mini" bindtap="hideSearch">取消</button>
  </view>

  <!-- 商品列表 -->
  <view class="goods-list">
    <view 
      wx:for="{{goodsList}}" 
      wx:key="_id"
      class="goods-item"
      data-id="{{item._id}}"
      bindtap="goToDetail"
    >
      <image src="{{item.images && item.images[0] ? item.images[0] : '/images/default.png'}}" mode="aspectFill" />
      <view class="info">
        <text class="title">{{item.title}}</text>
        <text class="price">¥{{item.price}}</text>
        <text class="status-tag" wx:if="{{item.status !== 'on'}}">
          {{item.status === 'sold' ? '已售' : '已下架'}}
        </text>
      </view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading" wx:if="{{loading}}">加载中...</view>
  <view class="no-more" wx:if="{{!hasMore && goodsList.length > 0}}">没有更多了</view>
  <view class="empty" wx:if="{{!loading && goodsList.length == 0}}">暂无商品</view>

  <!-- 悬浮发布按钮 -->
  <view class="publish-btn" bindtap="goToPublish">
    <text>+</text>
  </view>
</view>