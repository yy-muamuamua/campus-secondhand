<view class="page">
  <view class="header">
    <scroll-view scroll-x class="category-scroll">
      <view class="category-list">
        <view 
          wx:for="{{categories}}" 
          wx:key="index"
          class="category-item {{currentCategory === item ? 'active' : ''}}"
          data-category="{{item}}"
          bindtap="switchCategory"
        >{{item}}</view>
      </view>
    </scroll-view>
    <view class="filter-icons">
      <view class="icon-item" bindtap="toggleSortPanel">
        <mp-icon type="sort" size="24" color="{{showSortPanel ? '#1aad19' : '#999999'}}" />
      </view>
      <view class="icon-item" bindtap="togglePriceFilter">
        <mp-icon type="filter" size="24" color="{{showPriceFilter ? '#1aad19' : '#999999'}}" />
      </view>
      <view class="search-icon" bindtap="showSearch">
        <mp-icon type="search" size="24" color="#999999" />
      </view>
    </view>
  </view>

  <view class="sort-panel" wx:if="{{showSortPanel}}">
    <view 
      wx:for="{{sortOptions}}" 
      wx:key="index"
      class="sort-option {{sortIndex === index ? 'active' : ''}}"
      data-index="{{index}}"
      bindtap="selectSort"
    >{{item.label}}</view>
  </view>

  <view class="price-filter" wx:if="{{showPriceFilter}}">
    <view class="price-inputs">
      <input class="weui-input" placeholder="最低价" type="number" bindinput="onMinPriceInput" value="{{minPrice}}" />
      <text>—</text>
      <input class="weui-input" placeholder="最高价" type="number" bindinput="onMaxPriceInput" value="{{maxPrice}}" />
    </view>
    <view class="price-actions">
      <button class="weui-btn weui-btn_mini weui-btn_default" bindtap="clearPriceFilter">清除</button>
      <button class="weui-btn weui-btn_mini weui-btn_primary" bindtap="applyPriceFilter">确定</button>
    </view>
  </view>

  <view class="search-box" wx:if="{{showSearchInput}}">
    <input 
      class="weui-input"
      placeholder="输入商品名称" 
      bindinput="onSearchInput" 
      value="{{keyword}}"
      confirm-type="search"
      bindconfirm="onSearch"
    />
    <button class="weui-btn weui-btn_mini weui-btn_default" bindtap="hideSearch">取消</button>
  </view>

  <view class="goods-list">
    <view 
      wx:for="{{goodsList}}" 
      wx:key="_id"
      class="goods-item"
      data-id="{{item._id}}"
      bindtap="goToDetail"
    >
      <image src="{{item.images && item.images[0] ? item.images[0] : '/images/default.png'}}" mode="aspectFill" />
      <view class="info">
        <text class="title">{{item.title}}</text>
        <text class="price">¥{{item.price}}</text>
        <text class="status-tag" wx:if="{{item.status !== 'on'}}">
          {{item.status === 'sold' ? '已售' : '已下架'}}
        </text>
      </view>
    </view>
  </view>

  <view class="weui-loadmore" wx:if="{{loading}}">
    <view class="weui-loading"></view>
    <view class="weui-loadmore__tips">加载中...</view>
  </view>
  <view class="weui-loadmore" wx:if="{{!hasMore && goodsList.length > 0}}">
    <view class="weui-loadmore__tips">没有更多了</view>
  </view>
  <view class="weui-loadmore" wx:if="{{!loading && goodsList.length == 0}}">
    <view class="weui-loadmore__tips">暂无商品</view>
  </view>

  <view class="fab-button" bindtap="goToPublish">
    <mp-icon type="plus" size="32" color="#ffffff" />
  </view>

  <mp-toast id="toast" />
</view>
