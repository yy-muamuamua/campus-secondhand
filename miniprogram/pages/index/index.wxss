/* 首页样式 - WeUI风格 */
.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx;
}

.header {
  background: #ffffff;
  padding: 24rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid #e5e5e5;
}

.category-scroll {
  flex: 1;
  white-space: nowrap;
}

.category-list {
  display: inline-flex;
  gap: 24rpx;
}

.category-item {
  display: inline-block;
  padding: 16rpx 32rpx;
  font-size: 28rpx;
  color: #666666;
  background: #f5f5f5;
  border-radius: 40rpx;
  transition: all 0.2s ease;
}

.category-item.active {
  background: #1aad19;
  color: #ffffff;
}

.filter-icons {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-left: 24rpx;
}

.icon-item, .search-icon {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  border-radius: 50%;
}

.sort-panel {
  background: #ffffff;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #e5e5e5;
}

.sort-option {
  padding: 24rpx 32rpx;
  font-size: 28rpx;
  color: #666666;
  transition: all 0.2s ease;
}

.sort-option.active {
  color: #1aad19;
  font-weight: 600;
  background: #f6ffed;
}

.price-filter {
  background: #ffffff;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #e5e5e5;
}

.price-inputs {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.price-inputs input {
  flex: 1;
  height: 80rpx;
  padding: 0 24rpx;
  border: 1rpx solid #e5e5e5;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.price-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
}

.search-box {
  background: #ffffff;
  padding: 16rpx 32rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  border-bottom: 1rpx solid #e5e5e5;
}

.search-box input {
  flex: 1;
  height: 80rpx;
  padding: 0 24rpx;
  border: 1rpx solid #e5e5e5;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.goods-list {
  padding: 24rpx;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.goods-item {
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.goods-item image {
  width: 100%;
  height: 280rpx;
  object-fit: cover;
}

.goods-item .info {
  padding: 16rpx;
}

.goods-item .title {
  font-size: 26rpx;
  color: #333333;
  font-weight: 500;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.4;
}

.goods-item .price {
  font-size: 32rpx;
  color: #ff6600;
  font-weight: 600;
  margin-top: 8rpx;
}

.goods-item .status-tag {
  font-size: 20rpx;
  color: #999999;
  margin-top: 8rpx;
}

.weui-loadmore {
  text-align: center;
  padding: 40rpx 0;
}

.weui-loading {
  display: inline-block;
  width: 32rpx;
  height: 32rpx;
  border: 3rpx solid #d9d9d9;
  border-top-color: #1aad19;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-right: 16rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.weui-loadmore__tips {
  font-size: 28rpx;
  color: #999999;
}

.fab-button {
  position: fixed;
  bottom: 160rpx;
  right: 32rpx;
  width: 100rpx;
  height: 100rpx;
  background: #1aad19;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(26, 173, 25, 0.4);
  z-index: 999;
}

.fab-button:active {
  transform: scale(0.95);
  background: #129611;
}
