/* 首页样式 - 极简主义 + 莫兰迪色系 */

.page {
  padding-bottom: 140rpx;
  min-height: 100vh;
  background: var(--background-color);
}

/* 顶部导航栏 */
.header {
  position: sticky;
  top: 0;
  z-index: 100;
  background: var(--card-background);
  padding: 20rpx var(--spacing-md);
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: var(--shadow-sm);
}

.header-title {
  font-size: var(--font-xl);
  font-weight: 600;
  color: var(--text-primary);
  letter-spacing: 2rpx;
}

.header-actions {
  display: flex;
  align-items: center;
  gap: var(--spacing-md);
}

.action-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--primary-light);
  border-radius: 50%;
  transition: all 0.2s ease;
}

.action-btn:active {
  transform: scale(0.95);
  background: var(--border-color);
}

.action-btn image {
  width: 32rpx;
  height: 32rpx;
}

/* 搜索区域 */
.search-section {
  padding: var(--spacing-md);
  background: var(--card-background);
  margin-bottom: var(--spacing-sm);
}

.search-box {
  display: flex;
  align-items: center;
  background: var(--background-color);
  border-radius: var(--radius-lg);
  padding: var(--spacing-sm) var(--spacing-md);
  gap: var(--spacing-sm);
  transition: all 0.2s ease;
}

.search-box:focus-within {
  box-shadow: 0 0 0 2rpx var(--primary-light);
}

.search-icon {
  width: 36rpx;
  height: 36rpx;
  opacity: 0.5;
}

.search-input {
  flex: 1;
  border: none;
  background: transparent;
  font-size: var(--font-base);
  color: var(--text-primary);
  padding: 0;
}

.search-input:focus {
  outline: none;
}

/* 分类导航 */
.category-section {
  padding: var(--spacing-md);
  background: var(--card-background);
  margin-bottom: var(--spacing-sm);
}

.category-scroll {
  display: flex;
  overflow-x: auto;
  gap: var(--spacing-sm);
  padding: var(--spacing-xs) 0;
}

.category-scroll::-webkit-scrollbar {
  display: none;
}

.category-item {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--spacing-xs);
  padding: var(--spacing-sm) var(--spacing-md);
  border-radius: var(--radius-lg);
  transition: all 0.2s ease;
  min-width: 100rpx;
}

.category-item.active {
  background: var(--primary-light);
}

.category-item-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--background-color);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  transition: all 0.2s ease;
}

.category-item.active .category-item-icon {
  background: var(--primary-color);
  color: #FFFFFF;
}

.category-item-label {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  transition: all 0.2s ease;
}

.category-item.active .category-item-label {
  color: var(--primary-color);
  font-weight: 500;
}

/* 排序筛选栏 */
.filter-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-sm) var(--spacing-md);
  background: var(--card-background);
}

.filter-left {
  display: flex;
  align-items: center;
  gap: var(--spacing-md);
}

.sort-item {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  padding: 8rpx 16rpx;
  border-radius: var(--radius-md);
  transition: all 0.2s ease;
}

.sort-item.active {
  background: var(--primary-light);
  color: var(--primary-color);
}

.filter-right {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
}

.filter-btn {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--background-color);
  border-radius: var(--radius-md);
  transition: all 0.2s ease;
}

.filter-btn:active {
  background: var(--primary-light);
}

/* 商品列表 */
.goods-section {
  padding: var(--spacing-md);
}

.goods-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--spacing-md);
}

.goods-card {
  background: var(--card-background);
  border-radius: var(--radius-xl);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
  transition: all 0.3s ease;
}

.goods-card:active {
  transform: translateY(-4rpx);
  box-shadow: var(--shadow-md);
}

.goods-image-wrapper {
  position: relative;
  width: 100%;
  padding-top: 100%;
}

.goods-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.goods-status {
  position: absolute;
  top: var(--spacing-sm);
  right: var(--spacing-sm);
  padding: 6rpx 12rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: var(--radius-sm);
  font-size: var(--font-xs);
  color: var(--text-secondary);
}

.goods-content {
  padding: var(--spacing-md);
}

.goods-title {
  font-size: var(--font-sm);
  font-weight: 500;
  color: var(--text-primary);
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: var(--spacing-xs);
}

.goods-price-row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: var(--spacing-sm);
}

.goods-price {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--accent-pink);
}

.goods-meta {
  font-size: var(--font-xs);
  color: var(--text-tertiary);
}

/* 加载状态 */
.loading-section {
  padding: 80rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--spacing-md);
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 3rpx solid var(--border-color);
  border-top-color: var(--primary-color);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: var(--font-sm);
  color: var(--text-tertiary);
}

.no-more-text {
  font-size: var(--font-sm);
  color: var(--text-tertiary);
  text-align: center;
  padding: var(--spacing-lg) 0;
}

/* 空状态 */
.empty-section {
  padding: 150rpx var(--spacing-lg);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--spacing-lg);
}

.empty-icon {
  width: 160rpx;
  height: 160rpx;
  background: var(--primary-light);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  color: var(--primary-color);
}

.empty-title {
  font-size: var(--font-md);
  font-weight: 500;
  color: var(--text-secondary);
}

.empty-desc {
  font-size: var(--font-sm);
  color: var(--text-tertiary);
  text-align: center;
}

.empty-action {
  margin-top: var(--spacing-md);
  padding: var(--spacing-sm) var(--spacing-xl);
  background: var(--primary-color);
  color: #FFFFFF;
  border-radius: var(--radius-lg);
  font-size: var(--font-base);
  transition: all 0.2s ease;
}

.empty-action:active {
  background: var(--primary-dark);
}

/* 悬浮发布按钮 */
.floating-publish {
  position: fixed;
  bottom: 160rpx;
  right: var(--spacing-md);
  width: 96rpx;
  height: 96rpx;
  background: var(--primary-color);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-lg);
  transition: all 0.3s ease;
  z-index: 999;
}

.floating-publish:active {
  transform: scale(0.95);
  background: var(--primary-dark);
}

.publish-icon {
  width: 40rpx;
  height: 40rpx;
  stroke: #FFFFFF;
  stroke-width: 2;
}

/* 底部导航 */
.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--card-background);
  padding: var(--spacing-sm) 0;
  padding-bottom: calc(var(--spacing-sm) + env(safe-area-inset-bottom));
  display: flex;
  box-shadow: 0 -2rpx 12rpx rgba(107, 142, 123, 0.08);
  z-index: 1000;
}

.nav-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: var(--spacing-xs) 0;
  transition: all 0.2s ease;
}

.nav-item.active .nav-icon {
  opacity: 1;
}

.nav-item:not(.active) .nav-icon {
  opacity: 0.5;
}

.nav-icon {
  width: 44rpx;
  height: 44rpx;
  transition: all 0.2s ease;
}

.nav-label {
  font-size: var(--font-xs);
  color: var(--text-tertiary);
  transition: all 0.2s ease;
}

.nav-item.active .nav-label {
  color: var(--primary-color);
  font-weight: 500;
}

/* 响应式设计 */
@media screen and (min-width: 750rpx) {
  .goods-grid {
    grid-template-columns: repeat(3, 1fr);
  }
  
  .goods-image-wrapper {
    padding-top: 80%;
  }
}

@media screen and (max-width: 320rpx) {
  .goods-grid {
    grid-template-columns: 1fr;
  }
  
  .goods-image-wrapper {
    padding-top: 120%;
  }
}
