/* pages/orderList/index.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.tabs {
  display: flex;
  background-color: #ffffff;
  padding: 0 20rpx;
  border-bottom: 1rpx solid #eeeeee;
}

.tab-item {
  flex: 1;
  position: relative;
  text-align: center;
  padding: 30rpx 0;
  font-size: 28rpx;
  color: #999999;
}

.tab-item.active {
  color: #1989fa;
  font-weight: 500;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background-color: #1989fa;
  border-radius: 2rpx;
}

.badge {
  position: absolute;
  top: 10rpx;
  right: 30rpx;
  min-width: 32rpx;
  height: 32rpx;
  background-color: #f56c6c;
  color: #ffffff;
  font-size: 20rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 150rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}

.order-list {
  padding: 20rpx;
}

.order-item {
  background-color: #ffffff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.order-no {
  font-size: 24rpx;
  color: #999999;
}

.order-status {
  font-size: 26rpx;
  font-weight: 500;
}

.order-status.pending_payment { color: #f56c6c; }
.order-status.paid { color: #e6a23c; }
.order-status.shipped { color: #1989fa; }
.order-status.received { color: #67c23a; }
.order-status.completed { color: #999999; }
.order-status.cancelled { color: #999999; }
.order-status.refunding { color: #e6a23c; }
.order-status.refunded { color: #999999; }

.order-content {
  display: flex;
  padding: 24rpx;
  gap: 20rpx;
}

.goods-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background-color: #f5f5f5;
}

.goods-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.goods-title {
  font-size: 28rpx;
  color: #333333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.goods-price {
  font-size: 32rpx;
  color: #f56c6c;
  font-weight: 600;
}

.goods-quantity {
  font-size: 24rpx;
  color: #999999;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background-color: #fafafa;
}

.order-time {
  font-size: 22rpx;
  color: #999999;
}

.order-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  padding: 12rpx 32rpx;
  font-size: 24rpx;
  border-radius: 32rpx;
  border: 1rpx solid #dddddd;
  background-color: #ffffff;
  color: #666666;
}

.action-btn.primary {
  background-color: #1989fa;
  border-color: #1989fa;
  color: #ffffff;
}