/* 订单列表页面样式 - WeUI风格 */
.page {
  min-height: 100vh;
  background: #f5f5f5;
}

.weui-tabs {
  background: #ffffff;
}

.weui-tabs-bar {
  display: flex;
  border-bottom: 1rpx solid #e5e5e5;
}

.weui-tabs-bar__item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  position: relative;
}

.weui-tabs-bar__title {
  font-size: 28rpx;
  color: #666666;
  display: inline-block;
}

.weui-tabs-bar__title.active {
  color: #1aad19;
  font-weight: 600;
}

.weui-badge {
  display: inline-block;
  padding: 4rpx 12rpx;
  font-size: 20rpx;
  background: #f5f5f5;
  border-radius: 20rpx;
  margin-left: 8rpx;
}

.page-content {
  padding: 24rpx;
}

.order-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.weui-panel {
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
}

.weui-panel__hd {
  padding: 24rpx 32rpx;
  font-size: 24rpx;
  color: #999999;
  border-bottom: 1rpx solid #e5e5e5;
}

.weui-panel__bd {
  padding: 24rpx 32rpx;
}

.weui-media-box {
  display: flex;
  gap: 24rpx;
}

.weui-media-box__hd {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  overflow: hidden;
}

.weui-media-box__thumb {
  width: 100%;
  height: 100%;
}

.weui-media-box__bd {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.weui-media-box__title {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.weui-media-box__desc {
  font-size: 24rpx;
  color: #999999;
}

.weui-media-box__info {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.weui-media-box__info .price {
  font-size: 32rpx;
  color: #ff6600;
  font-weight: 600;
}

.weui-media-box__info .status {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 4rpx;
}

.status-pending_payment {
  background: #fff7e6;
  color: #ff6600;
}

.status-paid, .status-shipped {
  background: #e6f7ff;
  color: #1890ff;
}

.status-received {
  background: #f6ffed;
  color: #52c41a;
}

.status-completed {
  background: #f5f5f5;
  color: #999999;
}

.weui-panel__ft {
  padding: 16rpx 32rpx 24rpx;
}

.order-time {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 16rpx;
}

.order-actions {
  display: flex;
  gap: 16rpx;
  justify-content: flex-end;
}

.weui-btn_mini {
  padding: 0 24rpx;
  font-size: 24rpx;
  line-height: 2;
  border-radius: 4rpx;
}

.weui-btn_primary {
  background-color: #1aad19;
}

.weui-btn_default {
  background-color: #ffffff;
  color: #666666;
  border: 1rpx solid #d9d9d9;
}

.weui-loadmore {
  text-align: center;
  padding: 100rpx 0;
}

.weui-loadmore__tips {
  font-size: 28rpx;
  color: #999999;
}
