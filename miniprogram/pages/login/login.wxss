/* 登录页面样式 - WeUI风格 */
.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20px;
}

.login-container {
  padding-top: 100rpx;
}

.header {
  text-align: center;
  margin-bottom: 80rpx;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: 600;
  color: #1aad19;
  margin-bottom: 16rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: #999999;
}

.weui-cells {
  margin-top: 40rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.weui-cell {
  padding: 24rpx 32rpx;
}

.weui-label {
  width: 140rpx;
  font-size: 28rpx;
  color: #333333;
}

.weui-input {
  font-size: 28rpx;
  color: #333333;
}

.btn-area {
  margin-top: 80rpx;
  padding: 0 32rpx;
}

.weui-btn {
  margin-bottom: 24rpx;
  border-radius: 8rpx;
}

.weui-btn_primary {
  background-color: #1aad19;
}

.weui-btn_primary:not(.weui-btn_disabled):active {
  background-color: #129611;
}

.weui-btn_default {
  background-color: #ffffff;
  color: #1aad19;
  border: 1rpx solid #1aad19;
}
