/* 商品详情页样式 - 极简主义 + 莫兰迪色系 */

.page {
  padding-bottom: 140rpx;
  min-height: 100vh;
  background: var(--background-color);
}

/* 图片轮播 */
.swiper-container {
  background: var(--card-background);
}

.swiper-container swiper {
  height: 600rpx;
}

.swiper-container image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.swiper-dot {
  background: rgba(255, 255, 255, 0.6);
}

.swiper-dot.active {
  background: var(--primary-color);
}

/* 商品信息卡片 */
.info-card {
  background: var(--card-background);
  margin: -30rpx var(--spacing-md) var(--spacing-sm);
  padding: var(--spacing-lg);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-md);
  position: relative;
  z-index: 10;
}

.goods-title {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.4;
  margin-bottom: var(--spacing-md);
}

.price-row {
  display: flex;
  align-items: baseline;
  gap: var(--spacing-sm);
  margin-bottom: var(--spacing-md);
}

.price-symbol {
  font-size: var(--font-md);
  color: var(--accent-pink);
  font-weight: 500;
}

.price-value {
  font-size: var(--font-xxl);
  font-weight: 600;
  color: var(--accent-pink);
}

.price-label {
  font-size: var(--font-xs);
  color: var(--text-tertiary);
}

.goods-desc {
  font-size: var(--font-base);
  color: var(--text-secondary);
  line-height: 1.6;
  white-space: pre-wrap;
  margin-bottom: var(--spacing-md);
}

.goods-meta {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacing-md);
  padding-top: var(--spacing-md);
  border-top: 1rpx solid var(--border-color);
}

.meta-item {
  font-size: var(--font-sm);
  color: var(--text-tertiary);
  display: flex;
  align-items: center;
  gap: var(--spacing-xs);
}

.meta-icon {
  width: 24rpx;
  height: 24rpx;
}

/* 卖家信息卡片 */
.seller-card {
  background: var(--card-background);
  margin: 0 var(--spacing-md) var(--spacing-sm);
  padding: var(--spacing-lg);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-sm);
}

.section-header {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  margin-bottom: var(--spacing-md);
}

.section-line {
  width: 4rpx;
  height: 28rpx;
  background: var(--primary-color);
  border-radius: 2rpx;
}

.section-title {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--text-primary);
}

.seller-info {
  display: flex;
  align-items: center;
  padding: var(--spacing-sm);
  background: var(--background-color);
  border-radius: var(--radius-lg);
}

.seller-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  margin-right: var(--spacing-md);
  border: 2rpx solid var(--border-color);
}

.seller-detail {
  flex: 1;
}

.seller-name {
  font-size: var(--font-md);
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.seller-id {
  font-size: var(--font-sm);
  color: var(--text-tertiary);
}

.contact-btn {
  padding: var(--spacing-sm) var(--spacing-lg);
  background: var(--primary-light);
  color: var(--primary-color);
  border-radius: var(--radius-md);
  font-size: var(--font-sm);
  font-weight: 500;
}

.contact-btn:active {
  background: var(--border-color);
}

/* 留言区域 */
.message-card {
  background: var(--card-background);
  margin: 0 var(--spacing-md) var(--spacing-sm);
  padding: var(--spacing-lg);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-sm);
}

.message-list {
  margin-bottom: var(--spacing-lg);
}

.message-item {
  padding: var(--spacing-md) 0;
  border-bottom: 1rpx solid var(--border-color);
  animation: fadeIn 0.3s ease-out;
}

.message-item:last-child {
  border-bottom: none;
}

.message-header {
  display: flex;
  align-items: center;
  margin-bottom: var(--spacing-sm);
}

.message-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin-right: var(--spacing-md);
  border: 1rpx solid var(--border-color);
}

.message-nickname {
  font-size: var(--font-base);
  font-weight: 500;
  color: var(--text-primary);
  flex: 1;
}

.message-time {
  font-size: var(--font-xs);
  color: var(--text-tertiary);
}

.message-content {
  font-size: var(--font-base);
  color: var(--text-primary);
  line-height: 1.5;
  margin-left: calc(64rpx + var(--spacing-md));
  margin-bottom: var(--spacing-sm);
  white-space: pre-wrap;
}

.reply-box {
  background: var(--primary-light);
  padding: var(--spacing-md);
  border-radius: var(--radius-md);
  margin-left: calc(64rpx + var(--spacing-md));
  border-left: 4rpx solid var(--primary-color);
}

.reply-label {
  font-size: var(--font-sm);
  font-weight: 500;
  color: var(--primary-color);
  margin-right: var(--spacing-xs);
}

.reply-content {
  font-size: var(--font-sm);
  color: var(--text-secondary);
}

.reply-time {
  font-size: var(--font-xs);
  color: var(--text-tertiary);
  margin-top: 4rpx;
  text-align: right;
}

.reply-input-area {
  margin-left: calc(64rpx + var(--spacing-md));
  margin-top: var(--spacing-sm);
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  padding: var(--spacing-sm);
  background: var(--background-color);
  border-radius: var(--radius-md);
}

.reply-input {
  flex: 1;
  border: none;
  background: transparent;
  font-size: var(--font-sm);
}

.reply-btn {
  padding: 8rpx var(--spacing-md);
  background: var(--primary-color);
  color: #FFFFFF;
  border-radius: var(--radius-sm);
  font-size: var(--font-xs);
}

.reply-btn:active {
  background: var(--primary-dark);
}

/* 留言输入框 */
.new-message-area {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-sm);
}

.message-textarea {
  flex: 1;
  min-height: 120rpx;
  padding: var(--spacing-md);
  background: var(--background-color);
  border-radius: var(--radius-md);
  font-size: var(--font-base);
  border: none;
  resize: none;
}

.message-textarea:focus {
  outline: none;
}

.submit-row {
  display: flex;
  justify-content: flex-end;
}

.submit-btn {
  padding: var(--spacing-sm) var(--spacing-xl);
  background: var(--primary-color);
  color: #FFFFFF;
  border-radius: var(--radius-md);
  font-size: var(--font-base);
}

.submit-btn:active {
  background: var(--primary-dark);
}

/* 底部操作栏 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--card-background);
  padding: var(--spacing-sm) var(--spacing-md);
  padding-bottom: calc(var(--spacing-sm) + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  box-shadow: 0 -2rpx 12rpx rgba(107, 142, 123, 0.08);
  z-index: 1000;
}

.action-btn {
  flex: 1;
  height: 72rpx;
  border-radius: var(--radius-lg);
  font-size: var(--font-base);
  font-weight: 500;
  transition: all 0.2s ease;
}

.action-btn-primary {
  background: var(--primary-color);
  color: #FFFFFF;
}

.action-btn-primary:active {
  background: var(--primary-dark);
}

.action-btn-secondary {
  background: var(--primary-light);
  color: var(--primary-color);
}

.action-btn-secondary:active {
  background: var(--border-color);
}

/* 卖家快捷操作 */
.seller-actions {
  position: fixed;
  bottom: 140rpx;
  right: var(--spacing-md);
  z-index: 999;
}

.seller-btn {
  padding: var(--spacing-sm) var(--spacing-lg);
  background: var(--accent-blue);
  color: #FFFFFF;
  border-radius: var(--radius-lg);
  font-size: var(--font-sm);
  box-shadow: var(--shadow-md);
}

.seller-btn:active {
  background: #7A94A4;
}

/* 加载状态 */
.loading-container {
  padding: 150rpx var(--spacing-lg);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--spacing-md);
}

/* 响应式设计 */
@media screen and (min-width: 750rpx) {
  .page {
    max-width: 750rpx;
    margin: 0 auto;
    box-shadow: 0 0 24rpx rgba(0, 0, 0, 0.1);
  }
  
  .swiper-container swiper {
    height: 700rpx;
  }
  
  .info-card,
  .seller-card,
  .message-card {
    margin-left: auto;
    margin-right: auto;
    max-width: calc(750rpx - var(--spacing-xl));
  }
  
  .action-bar {
    max-width: 750rpx;
    left: 50%;
    transform: translateX(-50%);
    border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  }
}

@media screen and (max-width: 320rpx) {
  .swiper-container swiper {
    height: 500rpx;
  }
  
  .goods-title {
    font-size: var(--font-md);
  }
  
  .price-value {
    font-size: var(--font-xl);
  }
  
  .info-card,
  .seller-card,
  .message-card {
    padding: var(--spacing-md);
  }
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}
