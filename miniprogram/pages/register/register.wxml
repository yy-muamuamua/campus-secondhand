<view class="page">
  <!-- 页面标题 -->
  <view class="header">
    <text class="title">注册账号</text>
  </view>

  <!-- 注册表单 -->
  <view class="form">
    <!-- 邮箱输入 -->
    <view class="form-item">
      <text class="label">邮箱</text>
      <input 
        placeholder="请输入邮箱" 
        bindinput="onEmailInput" 
        value="{{email}}"
        type="email"
      />
    </view>

    <!-- 验证码输入 -->
    <view class="form-item">
      <text class="label">验证码</text>
      <view class="verify-code-container">
        <input 
          placeholder="请输入验证码" 
          bindinput="onCodeInput" 
          value="{{code}}"
          type="number"
        />
        <button 
          class="send-code-btn" 
          bindtap="sendVerificationCode"
          disabled="{{countdown > 0}}"
        >
          {{countdown > 0 ? countdown + 's后重发' : '发送验证码'}}
        </button>
      </view>
    </view>

    <!-- 提交按钮 -->
    <view class="submit-section">
      <button 
        class="submit-btn" 
        bindtap="verifyEmail"
        disabled="{{!email || !code}}"
      >
        验证邮箱
      </button>
    </view>
  </view>

  <!-- 学生认证提示 -->
  <view class="tips">
    <text>验证邮箱后，您需要完成学生认证才能发布商品和留言</text>
  </view>
</view>