/* 注册页面样式 - WeUI风格 */
.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20px;
}

.header {
  text-align: center;
  margin-bottom: 60rpx;
  padding-top: 40rpx;
}

.title {
  font-size: 48rpx;
  font-weight: 600;
  color: #333333;
}

.weui-cells {
  margin-top: 0;
  border-radius: 16rpx;
  overflow: hidden;
}

.weui-cell {
  padding: 24rpx 32rpx;
}

.weui-label {
  width: 140rpx;
  font-size: 28rpx;
  color: #333333;
}

.weui-input {
  font-size: 28rpx;
  color: #333333;
}

.weui-btn_mini {
  padding: 0 24rpx;
  font-size: 24rpx;
  line-height: 2;
}

.btn-area {
  margin-top: 60rpx;
  padding: 0 32rpx;
}

.weui-btn {
  margin-bottom: 24rpx;
  border-radius: 8rpx;
}

.weui-btn_primary {
  background-color: #1aad19;
}

.weui-btn_primary:not(.weui-btn_disabled):active {
  background-color: #129611;
}

.weui-btn_default {
  background-color: #ffffff;
  color: #666666;
}

.tips {
  margin-top: 40rpx;
  padding: 0 32rpx;
  text-align: center;
}

.tip-text {
  font-size: 24rpx;
  color: #999999;
  line-height: 1.6;
}
