<view class="page">
  <view class="search-bar">
    <input
      class="search-input"
      placeholder="搜索商品"
      value="{{keyword}}"
      bindinput="onSearchInput"
      bindconfirm="handleSearch"
    />
    <button size="mini" bindtap="handleSearch">搜索</button>
    <button size="mini" bindtap="clearKeyword" wx:if="{{keyword}}">清除</button>
  </view>

  <view class="search-results">
    <view
      wx:for="{{searchResults}}"
      wx:key="_id"
      class="goods-item"
      data-id="{{item._id}}"
      bindtap="goToDetail"
    >
      <image src="{{item.images && item.images[0] ? item.images[0] : '/images/default.png'}}" mode="aspectFill" />
      <view class="info">
        <text class="title">{{item.title}}</text>
        <text class="price">¥{{item.price}}</text>
        <text class="status-tag" wx:if="{{item.status !== 'on'}}">
          {{item.status === 'sold' ? '已售' : '已下架'}}
        </text>
      </view>
    </view>
  </view>

  <view class="loading" wx:if="{{loading}}">加载中...</view>
  <view class="no-more" wx:if="{{!hasMore && searchResults.length > 0}}">没有更多了</view>
  <view class="empty" wx:if="{{!loading && searchResults.length === 0 && keyword}}">未找到相关商品</view>
  <view class="empty" wx:if="{{!loading && searchResults.length === 0 && !keyword}}">请输入搜索关键词</view>
</view>
