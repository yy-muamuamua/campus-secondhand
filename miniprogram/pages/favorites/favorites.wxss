.page {
  padding: 20rpx;
}
.goods-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}
.goods-item {
  width: 48%;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.1);
}
.goods-item image {
  width: 100%;
  height: 320rpx;
}
.info {
  padding: 16rpx;
}
.title {
  display: block;
  font-size: 28rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.price {
  display: block;
  font-size: 32rpx;
  color: #ff6a6a;
  font-weight: bold;
}
.empty, .loading {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
}