/* pages/chat/index.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  display: flex;
  flex-direction: column;
}

.message-list {
  flex: 1;
  padding: 20rpx;
}

.message-item {
  display: flex;
  margin-bottom: 24rpx;
}

.message-item.self {
  flex-direction: row-reverse;
}

.message-item.self .message-content {
  align-items: flex-end;
}

.message-item.self .message-bubble {
  background-color: #1989fa;
}

.message-item.self .message-bubble .message-text {
  color: #ffffff;
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background-color: #f0f0f0;
  flex-shrink: 0;
}

.message-content {
  display: flex;
  flex-direction: column;
  max-width: 70%;
  margin: 0 16rpx;
}

.message-bubble {
  background-color: #ffffff;
  padding: 20rpx 24rpx;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.message-bubble .message-text {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.5;
  word-break: break-all;
}

.message-time {
  font-size: 22rpx;
  color: #999999;
  margin-top: 8rpx;
}

.input-bar {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background-color: #ffffff;
  border-top: 1rpx solid #eeeeee;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.message-input {
  flex: 1;
  height: 72rpx;
  padding: 0 24rpx;
  background-color: #f5f5f5;
  border-radius: 36rpx;
  font-size: 28rpx;
}

.send-btn {
  margin-left: 20rpx;
  padding: 16rpx 40rpx;
  font-size: 28rpx;
  background-color: #1989fa;
  color: #ffffff;
  border-radius: 36rpx;
}

.send-btn.disabled {
  background-color: #cccccc;
}