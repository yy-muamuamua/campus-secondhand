.page {
  background: #f5f5f5;
  min-height: 100vh;
}
.tabs {
  display: flex;
  background: #fff;
  border-bottom: 1rpx solid #eee;
  position: sticky;
  top: 0;
  z-index: 10;
}
.tab-item {
  flex: 1;
  text-align: center;
  padding: 30rpx 0;
  font-size: 32rpx;
  color: #666;
}
.tab-item.active {
  color: #07c160;
  border-bottom: 2px solid #07c160;
}
.panel {
  padding: 20rpx;
}
.stat-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.stat-card .title {
  font-size: 32rpx;
  color: #333;
}
.stat-card .number {
  font-size: 48rpx;
  font-weight: bold;
  color: #07c160;
}
.filter-bar {
  background: #fff;
  padding: 20rpx;
  margin-bottom: 20rpx;
  border-radius: 16rpx;
}
.goods-item, .user-item, .message-item {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  padding: 20rpx;
  display: flex;
}
.goods-item image, .user-item image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
}
.info {
  flex: 1;
}
.title, .nickname {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}
.price, .student {
  font-size: 28rpx;
  color: #ff6a6a;
  margin-bottom: 10rpx;
}
.status {
  font-size: 26rpx;
  color: #999;
}
.actions {
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 10rpx;
}
.message-item {
  flex-direction: column;
}
.message-item .header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10rpx;
  font-size: 28rpx;
  color: #666;
}
.message-item .content {
  font-size: 30rpx;
  margin-bottom: 10rpx;
}
.message-item .reply {
  background: #f8f8f8;
  padding: 10rpx;
  border-radius: 8rpx;
  margin-top: 10rpx;
  font-size: 28rpx;
  color: #07c160;
}
.loading-more, .no-more {
  text-align: center;
  padding: 20rpx;
  color: #999;
}