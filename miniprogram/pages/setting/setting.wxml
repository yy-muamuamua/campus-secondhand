<view class="page">
  <view class="form">
    <view class="form-item">
      <text class="label">微信号</text>
      <input placeholder="请输入微信号" bindinput="onWechatInput" value="{{wechat}}" />
    </view>
    <view class="form-item">
      <text class="label">手机号</text>
      <input placeholder="请输入手机号" bindinput="onPhoneInput" value="{{phone}}" type="number" />
    </view>
  </view>

  <button type="primary" bindtap="save" loading="{{saving}}" disabled="{{saving}}">保存</button>

  <view class="loading" wx:if="{{loading}}">加载中...</view>
</view>