# 默认忽略的文件
/shelf/
/workspace.xml
# 已忽略包含查询文件的默认文件夹
/queries/
# Datasource local storage ignored files
/dataSources/
/dataSources.local.xml
# 基于编辑器的 HTTP 客户端请求
/httpRequests/
# JetBrains IDE 配置
.idea/

# VS Code 配置
.vscode/

# 微信小程序个人配置（防止不同开发者互相覆盖）
project.private.config.json

# 依赖（如果用了 npm）
node_modules/
miniprogram_npm/

# 云函数依赖（如果 cloudfunctions 里有自己的 node_modules 可忽略）
cloudfunctions/*/node_modules/

# 操作系统临时文件
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# 编译或日志文件
*.log
dist/